            <Icon name="ai_sparkle" size={18} color="var(--sky)" />
            <div style={{ flex: 1, minWidth: 0 }}>
              <div style={{ fontSize: 13.5, fontWeight: 700, color: "var(--sky-ink)", lineHeight: 1.3 }}>{state.lowRisk} are low-risk and follow the rules.</div>
              <div style={{ fontSize: 12, color: "var(--sky-ink)", opacity: .72, marginTop: 1 }}>Normal leave and expenses under ₹10,000.</div>
            </div>
          </div> :

        <div style={{ marginTop: 13, padding: "12px 13px", borderRadius: 12, background: "var(--positive-light)", display: "flex", alignItems: "center", gap: 11 }}>
            <Icon name="confirm" size={18} color="var(--positive)" />
            <div style={{ fontSize: 13.5, fontWeight: 700, color: "var(--positive)", lineHeight: 1.3 }}>AI approved {state.approved} for you.</div>
          </div>
        }

        {state.approved === 0 &&
        <Button variant="sky" size="m" full style={{ marginTop: 11 }} icon="ai_sparkle" onClick={onBulkApprove}>
            Approve {state.lowRisk} low-risk for me
          </Button>
        }
        {remaining > 0 &&
        <button onClick={onOpen} style={{
          width: "100%", marginTop: 9, background: "none", border: "none", cursor: "pointer", fontFamily: "inherit",
          fontSize: 13.5, fontWeight: 700, color: "var(--reliance-base)"
        }}>I'll check the other {remaining} myself</button>
        }
      </Card>
    </Widget>);

}

